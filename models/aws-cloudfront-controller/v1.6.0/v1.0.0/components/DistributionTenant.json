    "version": "cloudfront.services.k8s.aws/v1alpha1",
    "kind": "DistributionTenant",
    "schema": "{\n \"description\": \"DistributionTenant is the Schema for the DistributionTenants API\",\n \"properties\": {\n  \"spec\": {\n   \"description\": \"DistributionTenantSpec defines the desired state of DistributionTenant.\\n\\nThe distribution tenant.\",\n   \"properties\": {\n    \"connectionGroupID\": {\n     \"description\": \"The ID of the connection group to associate with the distribution tenant.\",\n     \"type\": \"string\"\n    },\n    \"connectionGroupRef\": {\n     \"description\": \"AWSResourceReferenceWrapper provides a wrapper around *AWSResourceReference\\ntype to provide more user friendly syntax for references using 'from' field\\nEx:\\nAPIIDRef:\\n\\n\\tfrom:\\n\\t  name: my-api\",\n     \"properties\": {\n      \"from\": {\n       \"description\": \"AWSResourceReference provides all the values necessary to reference another\\nk8s resource for finding the identifier(Id/ARN/Name)\",\n       \"properties\": {\n        \"name\": {\n         \"type\": \"string\"\n        },\n        \"namespace\": {\n         \"type\": \"string\"\n        }\n       },\n       \"type\": \"object\"\n      }\n     },\n     \"type\": \"object\"\n    },\n    \"customizations\": {\n     \"description\": \"Customizations for the distribution tenant. For each distribution tenant,\\nyou can specify the geographic restrictions, and the Amazon Resource Names\\n(ARNs) for the ACM certificate and WAF web ACL. These are specific values\\nthat you can override or disable from the multi-tenant distribution that\\nwas used to create the distribution tenant.\",\n     \"properties\": {\n      \"certificate\": {\n       \"description\": \"The Certificate Manager (ACM) certificate associated with your distribution.\",\n       \"properties\": {\n        \"arn\": {\n         \"type\": \"string\"\n        }\n       },\n       \"type\": \"object\"\n      },\n      \"geoRestrictions\": {\n       \"description\": \"The customizations that you specified for the distribution tenant for geographic\\nrestrictions.\",\n       \"properties\": {\n        \"locations\": {\n         \"items\": {\n          \"type\": \"string\"\n         },\n         \"type\": \"array\"\n        },\n        \"restrictionType\": {\n         \"type\": \"string\"\n        }\n       },\n       \"type\": \"object\"\n      },\n      \"webACL\": {\n       \"description\": \"The WAF web ACL customization specified for the distribution tenant.\",\n       \"properties\": {\n        \"action\": {\n         \"type\": \"string\"\n        },\n        \"arn\": {\n         \"type\": \"string\"\n        }\n       },\n       \"type\": \"object\"\n      }\n     },\n     \"type\": \"object\"\n    },\n    \"distributionID\": {\n     \"description\": \"The ID of the multi-tenant distribution to use for creating the distribution\\ntenant.\",\n     \"type\": \"string\"\n    },\n    \"distributionRef\": {\n     \"description\": \"AWSResourceReferenceWrapper provides a wrapper around *AWSResourceReference\\ntype to provide more user friendly syntax for references using 'from' field\\nEx:\\nAPIIDRef:\\n\\n\\tfrom:\\n\\t  name: my-api\",\n     \"properties\": {\n      \"from\": {\n       \"description\": \"AWSResourceReference provides all the values necessary to reference another\\nk8s resource for finding the identifier(Id/ARN/Name)\",\n       \"properties\": {\n        \"name\": {\n         \"type\": \"string\"\n        },\n        \"namespace\": {\n         \"type\": \"string\"\n        }\n       },\n       \"type\": \"object\"\n      }\n     },\n     \"type\": \"object\"\n    },\n    \"domains\": {\n     \"description\": \"The domains associated with the distribution tenant. You must specify at\\nleast one domain in the request.\",\n     \"items\": {\n      \"description\": \"The domain for the specified distribution tenant.\",\n      \"properties\": {\n       \"domain\": {\n        \"type\": \"string\"\n       }\n      },\n      \"type\": \"object\"\n     },\n     \"type\": \"array\"\n    },\n    \"enabled\": {\n     \"description\": \"Indicates whether the distribution tenant should be enabled when created.\\nIf the distribution tenant is disabled, the distribution tenant won't serve\\ntraffic.\",\n     \"type\": \"boolean\"\n    },\n    \"managedCertificateRequest\": {\n     \"description\": \"The configuration for the CloudFront managed ACM certificate request.\",\n     \"properties\": {\n      \"certificateTransparencyLoggingPreference\": {\n       \"type\": \"string\"\n      },\n      \"primaryDomainName\": {\n       \"type\": \"string\"\n      },\n      \"validationTokenHost\": {\n       \"type\": \"string\"\n      }\n     },\n     \"type\": \"object\"\n    },\n    \"name\": {\n     \"description\": \"The name of the distribution tenant. Enter a friendly identifier that is\\nunique within your Amazon Web Services account. This name can't be updated\\nafter you create the distribution tenant.\",\n     \"type\": \"string\",\n     \"x-kubernetes-validations\": [\n      {\n       \"message\": \"Value is immutable once set\",\n       \"rule\": \"self == oldSelf\"\n      }\n     ]\n    },\n    \"parameters\": {\n     \"description\": \"A list of parameter values to add to the resource. A parameter is specified\\nas a key-value pair. A valid parameter value must exist for any parameter\\nthat is marked as required in the multi-tenant distribution.\",\n     \"items\": {\n      \"description\": \"A list of parameter values to add to the resource. A parameter is specified\\nas a key-value pair. A valid parameter value must exist for any parameter\\nthat is marked as required in the multi-tenant distribution.\",\n      \"properties\": {\n       \"name\": {\n        \"type\": \"string\"\n       },\n       \"value\": {\n        \"type\": \"string\"\n       }\n      },\n      \"type\": \"object\"\n     },\n     \"type\": \"array\"\n    },\n    \"tags\": {\n     \"description\": \"A complex type that contains Tag elements.\",\n     \"items\": {\n      \"description\": \"A complex type that contains Tag key and Tag value.\",\n      \"properties\": {\n       \"key\": {\n        \"description\": \"A string that contains Tag key.\\n\\nThe string length should be between 1 and 128 characters. Valid characters\\ninclude a-z, A-Z, 0-9, space, and the special characters _ - . : / = + @.\",\n        \"type\": \"string\"\n       },\n       \"value\": {\n        \"type\": \"string\"\n       }\n      },\n      \"type\": \"object\"\n     },\n     \"type\": \"array\"\n    }\n   },\n   \"required\": [\n    \"domains\",\n    \"name\"\n   ],\n   \"type\": \"object\"\n  }\n },\n \"title\": \"Distribution Tenant\",\n \"type\": \"object\"\n}"
